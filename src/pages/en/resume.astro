---
import Base from "../../layouts/Base.astro";
import siteCopy from "../../data/site-copy.json";
import experiences from "../../data/experiences.json";
import skills from "../../data/skills.json";
import { withBase } from "../../lib/base";

const copy = siteCopy.en;
const exp = experiences.en.timeline;
const edu = experiences.en.education;
const skillData = skills.en;
---

<Base lang="en" page="resume">
  <section class="page-hero container reveal">
    <h1 class="hero-heading">{copy.resume.heading}</h1>
    <p class="text-muted">{copy.resume.intro}</p>
    <div class="button-row">
      <a class="button button-primary" href={withBase("/resume-lee-ping-hui.pdf")}>{copy.resume.downloadLabel}</a>
    </div>
  </section>

  <section class="section container reveal">
    <h2 class="section-heading">{copy.resume.timelineHeading}</h2>
    <div class="timeline-list">
      {exp.map((item) => (
        <div class="timeline-item">
          <span class="timeline-marker"></span>
          <div>
            <div class="timeline-head">
              <h3>{item.org}</h3>
              <p class="text-soft">{item.period}</p>
            </div>
            <p class="text-muted">{item.title}</p>
            <p class="text-muted">{item.summary}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section container reveal">
    <h2 class="section-heading">{copy.resume.skillsHeading}</h2>
    <div class="card-grid">
      {skillData.categories.map((category: { heading: string; items: string[] }) => (
        <div class="card-panel">
          <h3>{category.heading}</h3>
          <div class="tag-list">
            {category.items.map((skill: string) => <span>{skill}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section container reveal">
    <h2 class="section-heading">{copy.resume.educationHeading}</h2>
    <div class="timeline-list">
      {edu.map((item) => (
        <div class="timeline-item">
          <span class="timeline-marker"></span>
          <div>
            <div class="timeline-head">
              <h3>{item.org}</h3>
              <p class="text-soft">{item.period}</p>
            </div>
            <p class="text-muted">{item.title}</p>
            <p class="text-muted">{item.summary}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
