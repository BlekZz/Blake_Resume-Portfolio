---
import Base from "../layouts/Base.astro";
import siteCopy from "../data/site-copy.json";
import projects from "../data/projects.json";
import { withBase } from "../lib/base";

const copy = siteCopy.zhTW;
const data = projects.zhTW;
---

<Base lang="zh-tw" page="projects">
  <section class="page-hero container reveal">
    <h1 class="hero-heading">{copy.projects.workCases.heading}</h1>
    <p class="text-muted">{copy.projects.workCases.intro}</p>
  </section>

  <section class="section container reveal">
    <div class="card-list">
      {data.workCases.map((item) => (
        <article class="card">
          <h3>{item.title}</h3>
          <p class="text-muted"><strong>情境：</strong>{item.situation}</p>
          <p class="text-muted"><strong>做法：</strong>{item.approach}</p>
          <p class="text-muted"><strong>結果：</strong>{item.result}</p>
          <div class="tag-list">
            {item.tags.map((tag: string) => <span>{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section container reveal">
    <h2 class="section-heading">{copy.projects.sideProjects.heading}</h2>
    <p class="text-muted">{copy.projects.sideProjects.intro}</p>
    <div class="card-grid">
      {data.sideProjects.map((item) => (
        <article class="card-panel">
          <h3>{item.name}</h3>
          <p class="text-muted">{item.description}</p>
          <div class="tag-list">
            {item.tags.map((tag: string) => <span>{tag}</span>)}
          </div>
          <div class="button-row" style="margin-top: 1rem;">
            {item.github && item.github.startsWith("http") && (
              <a class="text-link" href={item.github} target="_blank" rel="noreferrer">GitHub</a>
            )}
            {item.demo && (
              <a class="text-link" href={withBase(item.demo)} target="_blank" rel="noreferrer">Demo</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
